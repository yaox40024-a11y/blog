---
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='14'>📓</text></svg>" />
    <style is:global>
      :root {
        --bg: #fdfdfc;
        --fg: #1c1c1a;
        --muted: #6b6b66;
        --rule: #e5e5e0;
        --link: #1c5d99;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #16161a;
          --fg: #e8e8e4;
          --muted: #9a9a94;
          --rule: #2c2c32;
          --link: #7ab3e0;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.7 -apple-system, "Segoe UI", "Noto Sans SC", sans-serif;
      }
      .wrap { max-width: 46rem; margin: 0 auto; padding: 3rem 1.25rem 5rem; }
      a { color: var(--link); }
      header.site { display: flex; align-items: baseline; gap: 1.25rem; margin-bottom: 3rem; }
      header.site .brand { font-weight: 600; font-size: 1.1rem; color: var(--fg); text-decoration: none; }
      header.site nav a { color: var(--muted); text-decoration: none; font-size: .9rem; }
      header.site nav a:hover { color: var(--fg); }
      h1 { font-size: 1.9rem; line-height: 1.3; margin: 0 0 .5rem; }
      time { color: var(--muted); font-size: .85rem; }
      article :is(pre, table) { overflow-x: auto; }
      pre { background: var(--rule); padding: 1rem; border-radius: 6px; }
      code { font-family: "Cascadia Code", Consolas, monospace; font-size: .9em; }
      footer.site { margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid var(--rule); color: var(--muted); font-size: .85rem; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <a class="brand" href={base}>我的博客</a>
      </header>
      <slot />
    </div>
  </body>
</html>
